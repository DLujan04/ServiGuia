# ─────────────────────────────────────────────────────────────
#  .env.example  –  Variables de entorno para ServiGuía API
#  Copia este archivo como ".env" y llena los valores reales.
#  NUNCA subas el archivo .env real a GitHub.
# ─────────────────────────────────────────────────────────────

# ── OpenAI ─────────────────────────────────────────────────────
# Tu API key de OpenAI (necesaria para activar el LLM real)
# Activa la cuenta en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar (GPT-5 nano)
OPENAI_MODEL=gpt-5-nano

# ── Servidor ────────────────────────────────────────────────────
# Puerto en el que correrá la API (por defecto 8000)
PORT=8000

# Host (0.0.0.0 para aceptar conexiones externas)
HOST=0.0.0.0

# ── Entorno ─────────────────────────────────────────────────────
# "development" usa el mock_llm | "production" usa el LLM real
ENTORNO=development

# ── CORS ────────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (separados por coma)
# Ejemplo: http://localhost:3000,https://serviapp.mx
CORS_ORIGINS=*

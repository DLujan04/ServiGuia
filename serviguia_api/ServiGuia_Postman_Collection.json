    {
      "name": "🔬 Pruebas de validación del schema",
      "item": [
        {
          "name": "Schema — Descripción vacía (debe dar error 422)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/diagnostico",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descripcion\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Verifica que el servidor rechaza descripciones vacías con error 422."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rechaza descripcion vacia con 422', function() {",
                  "    pm.response.to.have.status(422);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Schema — Sin campo descripcion (debe dar error 422)",
          "request": {
